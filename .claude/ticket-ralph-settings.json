{
  "permissions": {
    "deny": [
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Edit(~/.npmrc)",
      "Write(~/.npmrc)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": ["docker *", "bkt *", "az *"],
    "filesystem": {
      "allowWrite": ["/tmp", "~/.ticket-ralph/tickets/"]
    },
    "network": {
      "allowedDomains": ["*"],
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    }
  }
}
